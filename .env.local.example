# Copy this file to .env.local for Docker Desktop local use:
#   cp .env.local.example .env.local

# Core application
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/lotpilot_bdc?schema=public"
REDIS_URL="redis://redis:6379"
AUTH_SESSION_SECRET="replace-me-with-a-long-random-secret"
APP_URL="http://localhost:3000"

# Seeded admin login
SEED_ADMIN_EMAIL="admin@lotpilot.local"
SEED_ADMIN_PASSWORD="change-me-now"

# AI provider
AI_PROVIDER="heuristic"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Twilio SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_INBOUND_WEBHOOK_URL=""
TWILIO_STATUS_WEBHOOK_URL=""
TWILIO_DEV_MODE="true"

# Email
EMAIL_PROVIDER="smtp"
EMAIL_DEV_MODE="true"
EMAIL_FROM_ADDRESS="LotPilot <noreply@lotpilot.local>"
EMAIL_REPLY_TO_ADDRESS="reply@lotpilot.local"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Public ingestion hardening
CAPTURE_API_TOKEN=""
EMAIL_INBOUND_TOKEN=""
PUBLIC_RATE_LIMIT_WINDOW_SECONDS="60"
CAPTURE_API_MAX_REQUESTS="120"
EMAIL_INBOUND_MAX_REQUESTS="120"

# Workflow / background jobs
WORKFLOW_QUEUE_ENABLED="true"
WORKFLOW_SAFE_MODE="true"
WORKFLOW_WORKER_CONCURRENCY="5"

# Agent defaults
AGENT_DEFAULT_TIMEZONE="America/New_York"

# Safe auto-response default
AUTO_RESPONSE_DEFAULT_MODE="SUGGEST_ONLY"

# Docker-only startup helpers
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
REDIS_HOST="redis"
REDIS_PORT="6379"
RUN_SEED_ON_START="true"

AUTH_SESSION_TTL_SECONDS=43200
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_BLOCK_MINUTES=30
