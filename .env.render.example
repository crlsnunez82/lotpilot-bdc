# Core
NODE_ENV=production
APP_URL=https://your-render-app.onrender.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB
REDIS_URL=redis://default:PASSWORD@HOST:6379
AUTH_SESSION_SECRET=replace-me-with-a-long-random-string

# Bootstrap admin
SEED_ADMIN_EMAIL=admin@lotpilot.local
SEED_ADMIN_PASSWORD=change-me-now

# Queue / workflow
WORKFLOW_QUEUE_ENABLED=true
WORKFLOW_SAFE_MODE=true
WORKFLOW_WORKER_CONCURRENCY=5

# AI
AI_PROVIDER=heuristic
OPENAI_API_KEY=

# Twilio
TWILIO_DEV_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
EMAIL_DEV_MODE=true
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Public endpoint hardening
CAPTURE_API_TOKEN=
EMAIL_INBOUND_TOKEN=
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
CAPTURE_API_MAX_REQUESTS=120
EMAIL_INBOUND_MAX_REQUESTS=120

# Auth / policy
AUTH_SESSION_TTL_SECONDS=43200
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_BLOCK_MINUTES=30

# Agent / behavior
AGENT_DEFAULT_TIMEZONE=America/New_York
AUTO_RESPONSE_DEFAULT_MODE=SUGGEST_ONLY
